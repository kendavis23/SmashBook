{
    "name": "smashbook-frontend",
    "private": true,
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "dev:staff": "turbo dev --filter=@repo/web-staff",
        "dev:player": "turbo dev --filter=@repo/web-player",
        "dev:website": "turbo dev --filter=@repo/website",
        "lint": "turbo lint",
        "test": "turbo test",
        "type-check": "turbo type-check",
        "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
    },
    "devDependencies": {
        "prettier": "^3.4.2",
        "turbo": "2.3.3",
        "typescript": "5.6.3"
    },
    "engines": {
        "node": ">=20",
        "pnpm": ">=9.12.3"
    },
    "packageManager": "pnpm@9.12.3"
}
