{
    "expo": {
        "name": "SmashBook",
        "slug": "smashbook-mobile",
        "version": "1.0.0",
        "orientation": "portrait",
        "scheme": "smashbook",
        "userInterfaceStyle": "automatic",
        "platforms": ["ios", "android"],
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "app.smashbook.mobile"
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#ffffff"
            },
            "package": "app.smashbook.mobile"
        },
        "plugins": [
            "expo-router",
            "expo-dev-client",
            [
                "@stripe/stripe-react-native",
                {
                    "merchantIdentifier": "merchant.app.smashbook.mobile",
                    "enableGooglePay": false
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}
